<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme.
         Fixed: Using standard DeviceDefault parent to support both Wear and Phone modules. -->
    <style name="Theme.OpenSeizureDetector" parent="android:Theme.DeviceDefault.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryDark">@color/purple_700</item>
        <item name="colorAccent">@color/teal_200</item>

        <!-- Status bar color. -->
        <item name="android:statusBarColor" tools:targetApi="21">?attr/colorPrimary</item>
        <item name="android:windowBackground">@color/black</item>
        <item name="android:textColorPrimary">@color/white</item>
    </style>
</resources>
